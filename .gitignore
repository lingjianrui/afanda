# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
dist/
build/
.eggs/

# Virtual environments / pixi
.pixi/
.venv/
venv/

# IDE
.idea/
.vscode/
*.iml

# Type stubs (generated)
typings/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# Output videos / images
*.mp4
*.avi
*.mov
*.png
*.jpg
*.jpeg

# Model cache — engines are built locally, not committed
~/.cache/avaturn/

# Local artifact storage — large binaries, not for version control
avaturn_storage/
artifact_storage/
artifacts/

# Internal artifact tracker files from the old S3 downloader
_metadata

# HuggingFace cache (typically in HOME, but in case it's local)
.cache/huggingface/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Locks (pixi.lock is committed; others are not)
*.lock
!pixi.lock

# Internal scripts — not for public repo
scripts/upload_to_hf.py

# Local secrets / env files — never commit
.env
.env.*
*.env
!*.env.example

# Misc
.DS_Store
*.log
*.tmp
